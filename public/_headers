# Cloudflare Pages headers config (https://developers.cloudflare.com/pages/configuration/headers/)
# Replaces next.config.ts headers() since static export doesn't support runtime headers.

/*
  X-DNS-Prefetch-Control: on
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Static HTML pages — keep edge cache short so freshly-deployed draw results
# show up quickly after each rebuild. The /api/draws.json Pages Function also
# fills the gap by serving live numbers client-side every 20s, but cutting
# this from 300s → 60s tightens the "visited the page directly" case too.
/*.html
  Cache-Control: public, max-age=60, s-maxage=60, stale-while-revalidate=300

# The live-draws Pages Function response — must not be cached aggressively
# by the browser (Function already sets its own short s-maxage at the edge).
/api/draws.json
  Cache-Control: public, max-age=10, s-maxage=30, stale-while-revalidate=60

# Long-cache static assets (Next.js hashes filenames for cache-busting)
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

/static/*
  Cache-Control: public, max-age=31536000, immutable

# Metadata files Next.js emits without a .png extension — pin Content-Type so
# Cloudflare doesn't serve them as application/octet-stream (would break social
# previews and favicons).
/opengraph-image
  Content-Type: image/png

/icon
  Content-Type: image/png

/apple-icon
  Content-Type: image/png
